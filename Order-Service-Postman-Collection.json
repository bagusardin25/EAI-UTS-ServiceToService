{
  "info": {
    "name": "Order Service API",
    "description": "Postman collection documentation for EAI UTS Project - Order Service. berjalan di port 8002.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Buyers",
      "item": [
        {
          "name": "Create Order (Checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"name\": \"Wireless Noise-Cancelling Headphones\",\n      \"price\": 2499000,\n      \"quantity\": 1\n    }\n  ],\n  \"shipping_address\": {\n    \"name\": \"Test User\",\n    \"phone\": \"081234567890\",\n    \"address_line\": \"Jl. Sudirman No. 1\",\n    \"city\": \"Jakarta\",\n    \"province\": \"DKI Jakarta\",\n    \"postal_code\": \"12190\",\n    \"notes\": \"Titip di pos satpam\"\n  },\n  \"payment_method\": \"bank_transfer\",\n  \"subtotal\": 2499000,\n  \"shipping_fee\": 25000,\n  \"total\": 2524000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get Own Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get Own Order by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          }
        },
        {
          "name": "Cancel Own Order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1/cancel", "host": ["{{base_url}}"], "path": ["api", "orders", "1", "cancel"] }
          }
        }
      ]
    },
    {
      "name": "Admin Only",
      "item": [
        {
          "name": "Get ALL Orders (Global)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/all", "host": ["{{base_url}}"], "path": ["api", "orders", "all"] }
          }
        },
        {
          "name": "Get Any Order by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/orders/1/status", "host": ["{{base_url}}"], "path": ["api", "orders", "1", "status"] }
          }
        },
        {
          "name": "Get User's Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/user/1", "host": ["{{base_url}}"], "path": ["api", "orders", "user", "1"] }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8002", "type": "string" },
    { "key": "token", "value": "ey...", "type": "string" }
  ]
}
