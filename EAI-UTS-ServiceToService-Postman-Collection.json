                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Gadget Terupdate\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{product_service}}/api/categories/1", "host": ["{{product_service}}"], "path": ["api", "categories", "1"] }
              }
            },
            {
              "name": "Delete Category",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json" },
