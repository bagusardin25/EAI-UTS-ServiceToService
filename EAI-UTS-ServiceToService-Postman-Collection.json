                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"New Product\",\n  \"price\": 150000,\n  \"stock\": 10,\n  \"category_id\": 1\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{product_service}}/api/products", "host": ["{{product_service}}"], "path": ["api", "products"] }
              }
            },
            {
              "name": "Update Product",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"price\": 200000\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{product_service}}/api/products/1", "host": ["{{product_service}}"], "path": ["api", "products", "1"] }
              }
            },
            {
              "name": "Delete Product",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{product_service}}/api/products/1", "host": ["{{product_service}}"], "path": ["api", "products", "1"] }
              }
            },
            {
              "name": "Create Category",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Gadget Baru\"\n}",
