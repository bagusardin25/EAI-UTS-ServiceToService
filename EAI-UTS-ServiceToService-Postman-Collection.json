              "name": "Get User's Orders",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders/user/1", "host": ["{{order_service}}"], "path": ["api", "orders", "user", "1"] }
              }
            }
          ]
        }
