{
  "info": {
    "name": "EAI-UTS-ServiceToService (Admin & Buyer)",
    "description": "Postman collection for EAI UTS Project Microservices. Memiliki endpoints lengkap untuk Role Admin dan Buyer di User Service (8000), Product Service (8001), dan Order Service (8002).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Service (Port 8000)",
      "item": [
        {
          "name": "Public / All Users",
          "item": [
            {
              "name": "Register",
              "request": {
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{user_service}}/api/register", "host": ["{{user_service}}"], "path": ["api", "register"] }
              }
            },
            {
              "name": "Login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{user_service}}/api/login", "host": ["{{user_service}}"], "path": ["api", "login"] }
              }
            },
            {
              "name": "Get Own Profile",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/auth/profile", "host": ["{{user_service}}"], "path": ["api", "auth", "profile"] }
              }
            },
            {
              "name": "Logout",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/logout", "host": ["{{user_service}}"], "path": ["api", "logout"] }
              }
            }
          ]
        },
        {
          "name": "Admin Only",
          "item": [
            {
              "name": "Get All Users",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/users", "host": ["{{user_service}}"], "path": ["api", "users"] }
              }
            },
            {
              "name": "Create User",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"admin2@example.com\",\n  \"password\": \"password\",\n  \"role\": \"admin\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{user_service}}/api/users", "host": ["{{user_service}}"], "path": ["api", "users"] }
              }
            },
            {
              "name": "Get User by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/users/1", "host": ["{{user_service}}"], "path": ["api", "users", "1"] }
              }
            },
            {
              "name": "Update User",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{user_service}}/api/users/1", "host": ["{{user_service}}"], "path": ["api", "users", "1"] }
              }
            },
            {
              "name": "Delete User",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/users/1", "host": ["{{user_service}}"], "path": ["api", "users", "1"] }
              }
            },
            {
              "name": "Get User Orders History",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{user_service}}/api/users/1/orders", "host": ["{{user_service}}"], "path": ["api", "users", "1", "orders"] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Product Service (Port 8001)",
      "item": [
        {
          "name": "Public / Buyers",
          "item": [
            {
              "name": "Get All Products",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": {
                  "raw": "{{product_service}}/api/products?page=1&limit=10",
                  "host": ["{{product_service}}"],
                  "path": ["api", "products"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "10" }
                  ]
                }
              }
            },
            {
              "name": "Get Product by ID",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{product_service}}/api/products/1", "host": ["{{product_service}}"], "path": ["api", "products", "1"] }
              }
            },
            {
              "name": "Search Products",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": {
                  "raw": "{{product_service}}/api/products/search?q=headphone",
                  "host": ["{{product_service}}"],
                  "path": ["api", "products", "search"],
                  "query": [{ "key": "q", "value": "headphone" }]
                }
              }
            },
            {
              "name": "Get Categories",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{product_service}}/api/categories", "host": ["{{product_service}}"], "path": ["api", "categories"] }
              }
            }
          ]
        },
