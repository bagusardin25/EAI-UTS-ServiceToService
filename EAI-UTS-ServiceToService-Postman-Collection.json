            {
              "name": "Get Any Order by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders/1", "host": ["{{order_service}}"], "path": ["api", "orders", "1"] }
