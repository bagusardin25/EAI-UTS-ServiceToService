                "url": { "raw": "{{product_service}}/api/categories/1", "host": ["{{product_service}}"], "path": ["api", "categories", "1"] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Order Service (Port 8002)",
      "item": [
        {
          "name": "Buyers",
          "item": [
            {
              "name": "Create Order (Checkout)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"name\": \"Wireless Noise-Cancelling Headphones\",\n      \"price\": 2499000,\n      \"quantity\": 1\n    }\n  ],\n  \"shipping_address\": {\n    \"name\": \"Test User\",\n    \"phone\": \"081234567890\",\n    \"address_line\": \"Jl. Sudirman No. 1\",\n    \"city\": \"Jakarta\",\n    \"province\": \"DKI Jakarta\",\n    \"postal_code\": \"12190\",\n    \"notes\": \"Titip di pos satpam\"\n  },\n  \"payment_method\": \"bank_transfer\",\n  \"subtotal\": 2499000,\n  \"shipping_fee\": 25000,\n  \"total\": 2524000\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{order_service}}/api/orders", "host": ["{{order_service}}"], "path": ["api", "orders"] }
              }
            },
            {
              "name": "Get Own Orders",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders", "host": ["{{order_service}}"], "path": ["api", "orders"] }
              }
            },
            {
              "name": "Get Own Order by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders/1", "host": ["{{order_service}}"], "path": ["api", "orders", "1"] }
              }
            },
            {
              "name": "Cancel Own Order",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders/1/cancel", "host": ["{{order_service}}"], "path": ["api", "orders", "1", "cancel"] }
              }
            }
          ]
        },
        {
          "name": "Admin Only",
          "item": [
            {
              "name": "Get ALL Orders (Global)",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": { "raw": "{{order_service}}/api/orders/all", "host": ["{{order_service}}"], "path": ["api", "orders", "all"] }
              }
